# Resend API key for inquiry emails (https://resend.com)
RESEND_API_KEY=re_xxxxx

# Required for prod: verify 2137.dev at resend.com/domains, then set:
# RESEND_FROM="2137.dev <hello@2137.dev>"

# Owner's Solana wallet address (receives USDC payments)
OWNER_WALLET=YourSolanaWalletPublicKey

# Payment amount in USDC (default: 50)
# PAYMENT_AMOUNT=50

# Helius RPC URL (optional — falls back to public mainnet RPC)
# HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=xxx

# Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF

# Telegram chat ID to receive payment notifications
TELEGRAM_CHAT_ID=123456789
